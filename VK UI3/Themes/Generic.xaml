<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:snow="using:VK_UI3.SnowFlake">

    <!--  Стиль для SnowFlakeEffect  -->
    <Style TargetType="snow:SnowFlakeEffect">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="snow:SnowFlakeEffect">
                    <!--  Canvas для снежинок  -->
                    <Canvas x:Name="PART_Canvas" Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
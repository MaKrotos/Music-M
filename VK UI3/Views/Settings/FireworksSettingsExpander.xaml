<?xml version="1.0" encoding="utf-8" ?>
<Expander x:Class="VK_UI3.Views.Settings.FireworksSettingsExpander"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:VK_UI3.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False" mc:Ignorable="d">

    <Expander.Header>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon VerticalAlignment="Center" FontSize="16" Glyph="&#xE112;" />
            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Настройки фейерверков" />
        </StackPanel>
    </Expander.Header>

    <Expander.Content>
        <StackPanel Spacing="12">
            <!-- Включение фейерверков -->
            <local:FireworksSetting AutomationProperties.HelpText="Включает или выключает анимацию фейерверков в приложении" AutomationProperties.Name="Включить фейерверки" />

            <!-- Количество ракет -->
            <StackPanel>
                <TextBlock AutomationProperties.HelpText="Отображает количество одновременно летящих ракет" AutomationProperties.Name="Количество ракет" Text="Количество ракет" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <local:FireworksCountSetting x:Name="fireworksCount" Grid.Column="0" AutomationProperties.HelpText="Регулирует количество одновременно летящих ракет фейерверка" AutomationProperties.Name="Ползунок количества ракет" />
                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" AutomationProperties.HelpText="Текущее значение количества ракет" AutomationProperties.Name="Значение количества ракет" Text="{x:Bind fireworksCount.Value, Mode=OneWay}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" AutomationProperties.HelpText="Единицы измерения количества ракет" AutomationProperties.Name="Единицы измерения ракет" Text="шт" />
                </Grid>
            </StackPanel>

            <!-- Режим радуги -->
            <local:FireworksRainbowSetting AutomationProperties.HelpText="Включает или выключает разноцветный режим фейерверков. При включении каждый фейерверк будет случайного цвета." AutomationProperties.Name="Разноцветные фейерверки" />

            <!-- Выбор цвета -->
            <StackPanel>
                <TextBlock AutomationProperties.HelpText="Выберите цвет фейерверков. Если включен режим радуги, этот цвет игнорируется." AutomationProperties.Name="Цвет фейерверков" Text="Цвет фейерверков" />
                <local:FireworksColorSetting HorizontalAlignment="Left" AutomationProperties.HelpText="Выберите цвет фейерверков. Если включен режим радуги, этот цвет игнорируется." AutomationProperties.Name="Палитра цвета фейерверков" />
            </StackPanel>

            <!-- Скорость анимации -->
            <StackPanel>
                <TextBlock AutomationProperties.HelpText="Регулирует скорость анимации фейерверков" AutomationProperties.Name="Скорость анимации" Text="Скорость анимации" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <local:FireworksSpeedSetting x:Name="fireworksSpeed" Grid.Column="0" AutomationProperties.HelpText="Регулирует скорость анимации фейерверков" AutomationProperties.Name="Ползунок скорости анимации" />
                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" AutomationProperties.HelpText="Текущее значение скорости анимации" AutomationProperties.Name="Значение скорости анимации" Text="{x:Bind fireworksSpeed.Value, Mode=OneWay}" />
                </Grid>
            </StackPanel>

            <!-- Максимум частиц -->
            <StackPanel>
                <TextBlock AutomationProperties.HelpText="Ограничивает максимальное количество частиц фейерверка для производительности" AutomationProperties.Name="Максимум частиц" Text="Максимум частиц" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <local:FireworksParticlesSetting x:Name="fireworksParticles" Grid.Column="0" AutomationProperties.HelpText="Ограничивает максимальное количество частиц фейерверка для производительности" AutomationProperties.Name="Ползунок максимума частиц" />
                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" AutomationProperties.HelpText="Текущее значение максимума частиц" AutomationProperties.Name="Значение максимума частиц" Text="{x:Bind fireworksParticles.Value, Mode=OneWay}" />
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" AutomationProperties.HelpText="Единицы измерения количества частиц" AutomationProperties.Name="Единицы измерения частиц" Text="шт" />
                </Grid>
            </StackPanel>

            <!-- Кнопка тестового запуска -->
            <Button x:Name="TestLaunchButton" HorizontalAlignment="Left" AutomationProperties.HelpText="Запускает несколько фейерверков для тестового просмотра" AutomationProperties.Name="Тестовый запуск фейерверков" Click="TestLaunchButton_Click" Content="Запустить тестовый фейерверк" />
        </StackPanel>
    </Expander.Content>
</Expander>
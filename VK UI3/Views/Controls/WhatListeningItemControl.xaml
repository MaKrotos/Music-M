<UserControl
    x:Class="VK_UI3.Views.Controls.WhatListeningItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VK_UI3.Views"
    xmlns:models="using:MusicX.Core.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Height="200" Width="400">
        <!-- Background Image Fill -->
        <Border CornerRadius="12">
            <Image Source="{x:Bind UserAvatar, Mode=OneWay}"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        </Border>
        
        <!-- Dark Overlay for Readability -->
        <Border CornerRadius="12"
                Background="Black"
                Opacity="0.4"/>

        <!-- Content Layout -->
        <Grid Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Name/Nickname -->
            <TextBlock Grid.Row="0"
                       Text="{x:Bind UserName, Mode=OneWay}"
                       Foreground="White"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- User Avatar / Primary Image -->
                <Ellipse Grid.Column="0" Width="100" Height="100" Fill="Silver" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <!-- Right: List of playlists/authors -->
                <ItemsControl Grid.Column="1" ItemsSource="{x:Bind Playlists, Mode=OneWay}" VerticalAlignment="Center">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ListeningContentItem">
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                                <FontIcon Glyph="{x:Bind Icon}" FontSize="16" Foreground="LightGray" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind Name}"
                                           Foreground="White"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Footer: Dynamic Social Network buttons -->
            <ItemsControl Grid.Row="2" ItemsSource="{x:Bind SocialLinks, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:SocialLinkItem">
                        <Button Width="40" Height="40"
                                Padding="0"
                                ToolTipService.ToolTip="{x:Bind Name}"
                                Background="{ThemeResource SystemAccentColor}"
                                CornerRadius="20">
                            <Button.Content>
                                <FontIcon Glyph="{x:Bind Icon}" FontSize="16" Foreground="White"/>
                            </Button.Content>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
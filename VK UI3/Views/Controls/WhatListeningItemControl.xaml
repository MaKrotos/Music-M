<UserControl
    x:Class="VK_UI3.Views.Controls.WhatListeningItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:VK_UI3.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:VK_UI3.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MusicX.Core.Models"
    xmlns:winui="using:WinUICommunity"
    mc:Ignorable="d">

    <Grid
        x:Name="mainGrid"
        Height="400"
        Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
        CornerRadius="10">

        <!--  Background Image Fill with Opacity Mask  -->
        <winui:OpacityMaskView
            Width="600"
            Margin="0,50,0,0"
            VerticalAlignment="Top">
            <winui:OpacityMaskView.OpacityMask>
                <LinearGradientBrush MappingMode="RelativeToBoundingBox" StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="1" Color="#00FFFFFF" />
                    <GradientStop Offset="0.03" Color="#00FFFFFF" />
                    <GradientStop Offset="0.5" Color="#FFFFFFFF" />
                    <GradientStop Offset="0.80" Color="#FFFFFFFF" />

                    <GradientStop Offset="0.95" Color="#00FFFFFF" />
                    <GradientStop Offset="1" Color="Transparent" />
                </LinearGradientBrush>
            </winui:OpacityMaskView.OpacityMask>
            <winui:OpacityMaskView>
                <winui:OpacityMaskView.OpacityMask>
                    <LinearGradientBrush MappingMode="RelativeToBoundingBox" StartPoint="1,1" EndPoint="0,1">
                        <GradientStop Offset="1" Color="#00FFFFFF" />
                        <GradientStop Offset="0.03" Color="#00FFFFFF" />
                        <GradientStop Offset="0.5" Color="#FFFFFFFF" />
                        <GradientStop Offset="0.80" Color="#FFFFFFFF" />

                        <GradientStop Offset="0.95" Color="#00FFFFFF" />
                        <GradientStop Offset="1" Color="Transparent" />
                    </LinearGradientBrush>
                </winui:OpacityMaskView.OpacityMask>

                <Grid>
                    <Image
                        x:Name="BackgroundImage"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Stretch="Uniform"
                        Visibility="Visible" />
                </Grid>
            </winui:OpacityMaskView>
        </winui:OpacityMaskView>

        <!--  Content Layout  -->
        <Grid Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  User Name Block  -->
            <Grid
                Padding="10"
                HorizontalAlignment="Left"
                Background="{ThemeResource CustomAlternativeAcrylicInAppBrush}"
                CornerRadius="8">

                <TextBlock
                    Grid.Row="0"
                    HorizontalAlignment="Left"
                    FontSize="30"
                    Foreground="White"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="{x:Bind UserName, Mode=OneWay}" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Right: List of playlists/authors  -->
                <ItemsControl
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    ItemsSource="{x:Bind Playlists, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="15" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ListeningContentItem">
                            <controls:ListeningContentItemControl />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!--  Footer: Social Network buttons  -->
            <ItemsControl Grid.Row="2" ItemsSource="{x:Bind SocialLinks, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel
                            HorizontalAlignment="Left"
                            Orientation="Horizontal"
                            Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:SocialLinkItem">
                        <controls:SocialLinkButtonControl SocialLink="{x:Bind Mode=OneWay}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>